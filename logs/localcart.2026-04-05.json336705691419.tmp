{"@timestamp":"2026-04-05T16:18:54.506043348Z","@version":"1","message":"\n    select\n        c1_0.id,\n        c1_0.created_at,\n        c1_0.created_by,\n        c1_0.deleted_at,\n        c1_0.is_deleted,\n        i1_0.cart_id,\n        i1_0.id,\n        i1_0.created_at,\n        i1_0.created_by,\n        i1_0.deleted_at,\n        i1_0.is_deleted,\n        i1_0.product_id,\n        p1_0.id,\n        p1_0.category_id,\n        p1_0.created_at,\n        p1_0.created_by,\n        p1_0.deleted_at,\n        p1_0.description,\n        p1_0.discount_price,\n        p1_0.is_active,\n        p1_0.is_deleted,\n        p1_0.is_featured,\n        p1_0.name,\n        p1_0.price,\n        p1_0.rating,\n        p1_0.sku,\n        p1_0.slug,\n        p1_0.stock,\n        p1_0.total_reviews,\n        p1_0.total_sales,\n        p1_0.updated_at,\n        p1_0.updated_by,\n        p1_0.vendor_id,\n        i1_0.quantity,\n        i1_0.updated_at,\n        i1_0.updated_by,\n        c1_0.updated_at,\n        c1_0.updated_by,\n        c1_0.user_id \n    from\n        carts c1_0 \n    left join\n        cart_items i1_0 \n            on c1_0.id=i1_0.cart_id \n    left join\n        products p1_0 \n            on p1_0.id=i1_0.product_id \n    where\n        c1_0.updated_at<? \n        and (\n            select\n                count(*) \n            from\n                cart_items i2_0 \n            where\n                c1_0.id=i2_0.cart_id\n        )>0","logger_name":"org.hibernate.SQL","thread_name":"scheduling-1","level":"DEBUG","level_value":10000,"application":"localcart","service":"localcart","env":"dev"}
